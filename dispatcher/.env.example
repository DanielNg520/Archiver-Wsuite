# dispatcher .env — copy to ~/.config/dispatcher/.env and fill in.
# These are SECRETS. Do not commit. Mode 600 recommended.

# ── Required: Telegram credentials ──────────────────────────────────────────
# Get api_id + api_hash from https://my.telegram.org -> API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1...
TELEGRAM_CHAT_ID=          # global default destination (numeric -100... or @username)

# ── Optional: Telegram routing overrides ────────────────────────────────────
# Resolution order: per-user > per-platform > global.
# TELEGRAM_CHAT_ID_X=
# TELEGRAM_CHAT_ID_TIKTOK=       # TikTok videos / non-live archive uploads
# TELEGRAM_CHAT_ID_TIKTOK_LIVE=  # TikTok live recordings from recorder
# TELEGRAM_CHAT_ID_INSTAGRAM=
# TELEGRAM_CHAT_ID_X_SOMEUSER=
# TELEGRAM_CHAT_ID_TIKTOK_LIVE_SOMEUSER=

# ── Optional: session file location ─────────────────────────────────────────
# TELEGRAM_SESSION=~/.config/dispatcher/session

# ── Optional: dispatcher tuning ─────────────────────────────────────────────
# DISPATCHER_DB=~/.config/dispatcher/dispatcher.db
# POLL_INTERVAL_S=2.0
# MAX_RETRIES=4
# RETRY_BASE_DELAY=2.0
# MAX_FLOOD_WAIT_S=600
# INTER_ALBUM_SLEEP=2.0
# STUCK_CLAIM_MIN=10
